# SXHKD - Keybindings
pgrep -x sxhkd > /dev/null || sxhkd &


# Activate Polybar
$HOME/.config/polybar/bspwm.sh


# Workspaces
bspc monitor HDMI-A-0 -d "" "" "" "" "" "" "" 
bspc monitor DisplayPort-0 -d "1" "2" "3" "4" "5" 


# Gaps and Borders
bspc config border_width           2
bspc config normal_border_color    "#222222"
#bspc config focused_border_color   "#859900"
#bspc config presel_feedback_color  "#073642"
bspc config focused_border_color   "#3071db"
bspc config presel_feedback_color  "#3071db"

bspc config window_gap             12
bspc config split_ratio            0.52
bspc config borderless_monocle     true
bspc config gapless_monocle        true
#bspc config focus_follows_pointer  true


# Window Rules
bspc rule -a Nitrogen              state=floating
bspc rule -a Ristretto             state=floating
bspc rule -a Gpick                 state=floating
bspc rule -a Toolkit               state=floating
bspc rule -a Parole                state=floating



# Autostart
setxkbmap de &
nitrogen --restore &
xsetroot -cursor_name left_ptr &
picom --experimental-backends &
unclutter -idle 3 -root &
#dunst &
#nitrogen --set-zoom-fill $HOME/.config/bspwm/wallpaper1.jpg &
#polybar-msg cmd hide; bspc config top_padding +0
#bspc desktop -f '^4' &
sleep 0.05
xset r rate 250 30 &
setxkbmap de neo &
