[colors]
include-file = ~/.config/polybar/doom-one.ini
padding   = 3
paddingrm = 5


[bar/bspwm]
monitor    = HDMI-A-0
enable-ipc = true

background = ${colors.base03}
foreground = ${colors.base1}
width      = 100%
height     = 21
offset-x   = 0%
offset-y   = 0%
radius     = 0.0

border-size  = 1
border-color = #222222

padding-left  = 0
padding-right = 1
line-size     = 2

module-margin-left  = 0
module-margin-right = 0
fixed-center        = true

font-0 = Clear Sans Medium:pixelsize=11;3
font-1 = UbuntuNerdFont:pixelsize=10;3
font-2 = UbuntuNerdFont:pixelsize=15;4

modules-left   = xmenu xworkspaces title
modules-center = 
modules-right  = menu-apps pulseaudio xkeyboard date

tray-position   = right
tray-padding    = 10
tray-background = ${colors.base03}
wm-restack      = bspwm
;override-redirect = true

cursor-click  = pointer
cursor-scroll = pointer

include-file = ~/.config/polybar/external-bar.ini
;:::::::::::::::::::::::::::::::::::::::::::::::;


; M O D U L E S ;

[module/xworkspaces]
type           = internal/xworkspaces
pin-workspaces = true
format         = <label-state>
enable-click   = true
enable-scroll  = true
format-padding = 0
format-font    = 2
icon-0 = 1
icon-1 = 2
icon-2 = 3
icon-3 = 4
icon-4 = 5
label-empty            = %name%
label-empty-foreground = ${colors.base01}
label-empty-background = ${colors.base03}
label-empty-padding    = ${colors.padding}
label-active            = %name%
label-active-foreground = ${colors.blue}
label-active-background = ${colors.base03}
label-active-padding    = ${colors.padding}
label-occupied            = %name%
label-occupied-foreground = ${colors.base1}
label-occupied-background = ${colors.base03}
label-occupied-padding    = ${colors.padding}
label-urgent            = %name%
label-urgent-foreground = ${colors.orange}
label-urgent-background = ${colors.base03}
label-urgent-padding    = ${colors.padding}


[module/title]
type = internal/xwindow
format                 = <label>
format-background      = ${colors.base03}
format-foreground      = ${colors.base1}
format-padding         = 2
label                  = %title%
label-maxlen           = 100
label-empty            = "-"
label-empty-foreground = ${colors.base01}


[module/xmenu]
type = custom/script
exec = echo " Ô°õ "
format-background = ${colors.base03}
format-foreground = ${colors.base1}
format-font       = 3
padding-right = ${colors.padding}
padding-left  = ${colors.padding}
click-left = ~/.config/xmenu/xmenu.sh


[module/vim]
type = custom/script
exec = echo "V"
format-foreground = ${colors.green}
format-background = ${colors.base03}
click-left = /usr/bin/nvim &
padding = 2


[module/akku]
type = custom/script
exec = head /sys/class/power_supply/BAT0/capacity
format-prefix = "Óā≤"
format-prefix-background = ${colors.volbg}
format-prefix-foreground = ${colors.akkubg}
label = ÔČĀ %output%%
label-background = ${colors.akkubg}
label-padding-left = 2
interval = 100


[module/xkeyboard]
type = internal/xkeyboard
format = <label-layout> <label-indicator>
format-prefix = "Ôźč  "
format-prefix-foreground = ${colors.violet}
layout-icon-default = 99
layout-icon-0 = de
layout-icon-1 = de;neo2
indicator-icon-default = ""
indicotor-icon-0 = caps lock;;CL
label-layout = %variant%
label-indicator-on = %name%
label-indicator-on-background = ${colors.magenta}
label-indicator-off = %icon%
format-padding = ${colors.padding}
padding = ${colors.paddingrm}


[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "cpu: "
format-prefix-background = ${colors.orange}
format-prefix-foreground = ${colors.base03}
format-underline = ${colors.orange}
label = %percentage:2%%
label-foreground = ${colors.orange}
label-padding = ${colors.padding}
padding = ${colors.paddingrm}


[module/memory]
type = internal/memory
interval = 2
format-prefix = "ÓÄ® "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = #4bffdc
label = %percentage_used%%


[module/wlan]
type = internal/network
interface = net1
interval = 3.0
format-connected = <ramp-signal> <label-connected>
format-connected-underline = #9f78e1
label-connected = %essid%
format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}
ramp-signal-0 = Óąė
ramp-signal-1 = Óąô
ramp-signal-2 = Óąö
ramp-signal-3 = Óąö
ramp-signal-4 = Óąö
ramp-signal-foreground = ${colors.foreground-alt}


[module/eth]
type = internal/network
interface = enp4s0
interval = 3.0
format-connected-underline = #55aa55
format-connected-prefix = "ÓÜú "
format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = %local_ip%
format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}


[module/date]
type = internal/date
interval                 = 5
format-prefix            = "ÔÄó "
format-prefix-background = ${colors.base03}
format-prefix-foreground = ${colors.orange}
;format-underline        = ${colors.cyan}
date                     = "%e. %b"
date-alt                 = " %Y-%m-%d"
label                    = %date% %time%
label-background         = ${colors.base03}
label-foreground         = ${colors.base1}
label-padding            = 0
time                     = %H:%M
time-alt                 = %H:%M:%S
padding-left             = ${colors.paddingrm}
padding-right            = 8


[module/pulseaudio]
type = internal/pulseaudio
format-volume-prefix            = " ÔÄ® "
format-volume-prefix-background = ${colors.background}
format-volume-prefix-foreground = ${colors.cyan}
format-volume                   = <label-volume>
label-volume                    = %percentage%%
label-volume-padding            = 1
label-volume-background         = ${colors.volbg}
label-volume-foreground         = ${colors.volfg}
label-muted                     = Ô™Ä muted
label-muted-foreground          = ${colors.red}
;bar-volume-width               = 10
;bar-volume-foreground-0        = #55aa55
;bar-volume-foreground-1        = #55aa55
;bar-volume-foreground-2        = #55aa55
;bar-volume-foreground-3        = #55aa55
;bar-volume-foreground-4        = #55aa55
;bar-volume-foreground-5        = #c23839
;bar-volume-foreground-6        = #ff5555
;bar-volume-gradient            = false
;bar-volume-indicator           = |
;bar-volume-indicator-font      = 2
;bar-volume-fill                = ‚ĒÄ
;bar-volume-fill-font           = 2
;bar-volume-empty               = ‚ĒÄ
;bar-volume-empty-font          = 2
;bar-volume-empty-foreground    = ${colors.foreground-alt}


[module/temperature]
type = internal/temperature
thermal-zone          = 0
warn-temperature      = 60
format                = <ramp> <label>
format-warn           = <ramp> <label-warn>
format-warn-underline = ${self.format-underline}
label                 = %temperature-c%
label-warn            = %temperature-c%
label-warn-foreground = ${colors.secondary}
;format-underline     = #f50a4d
;ramp-0               = ÓÉČ
;ramp-1               = ÓÉä
;ramp-2               = ÓÉč
;ramp-foreground      = ${colors.foreground-alt}

include-file = ~/.config/polybar/menu.ini
